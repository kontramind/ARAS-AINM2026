# --- MASTER SWITCH ---
# Set to 'azure_native' to use GPT-4/o4-mini
# Set to 'openai_compatible' to use DeepSeek/Mistral (Foundry)
LLM_PROVIDER=openai_compatible

# --- TEMPERATURE SETTING ---
# DeepSeek/GPT-4o often allow 0.0 to 1.0. 
# NOTE: o1-preview/mini often FORCE temperature=1.0.
LLM_TEMPERATURE=1.0

# --- SHARED SECRETS ---
# Since both are in the same Azure resource, they likely use the same Key.
# Paste your key here once, and it will be used below.
GLOBAL_AZURE_KEY=your-azure-key-here

# ======================================================
# CONFIGURATION A: AZURE NATIVE (GPT-4o, o1-mini)
# ======================================================
# This is for your standard "Azure OpenAI" deployments.
# It requires the specific API version.
AZURE_API_BASE=https://ainm2026-ai-service.cognitiveservices.azure.com/
AZURE_API_KEY=${GLOBAL_AZURE_KEY}
AZURE_DEPLOYMENT_NAME=o4-mini
AZURE_API_VERSION=2024-12-01-preview

# ======================================================
# CONFIGURATION B: OPENAI COMPATIBLE (DeepSeek, Mistral)
# ======================================================
# This acts like a standard OpenAI endpoint.
# NOTICE: We append "/openai/v1" to the base URL as per your DeepSeek example.
OPENAI_COMPATIBLE_BASE_URL=https://ainm2026-ai-service.cognitiveservices.azure.com/openai/v1
OPENAI_COMPATIBLE_API_KEY=${GLOBAL_AZURE_KEY}
OPENAI_COMPATIBLE_MODEL=DeepSeek-V3.1

# ======================================================
# EMBEDDINGS (Always use Azure Native for RAG)
# ======================================================
# We generally always want to use the stable Ada-002 model for embeddings,
# even if we use DeepSeek for the chat.
EMBEDDING_PROVIDER=azure_native
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ======================================================
# OFFLINE FALLBACK (Ollama)
# ======================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3