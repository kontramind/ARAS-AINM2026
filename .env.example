# --- LLM PROVIDER CONFIGURATION ---
# Options: azure, openai, ollama (offline)
LLM_PROVIDER=azure

# --- AZURE CONFIGURATION (From your project) ---
# Your Azure Endpoint (e.g., https://my-resource.openai.azure.com/)
AZURE_API_BASE=https://your-resource-name.openai.azure.com/
AZURE_API_KEY=your-azure-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment Names (The name you gave the model in Azure Portal)
AZURE_OPENAI_DEPLOYMENT_MODEL=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# --- OFFLINE FALLBACK (Keep this just in case!) ---
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# --- OTHER CONFIGURATION ---
LLM_TEMPERATURE=1